# ============================================================================
# Orixa Enterprise Intelligence OS - Environment Template
# Copy this file to '.env' and provide your secure credential values.
# ============================================================================

# Security and JWT configurations
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=11520
NODE_ENV=production

# Database (PostgreSQL) configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=orixa_db
POSTGRES_PORT=5432

# Caching (Redis) configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Gemini AI Platform Integrations
GEMINI_API_KEY=
